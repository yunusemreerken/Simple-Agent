# ── HuggingFace ───────────────────────────────────────────────────────────
# Hub model adı veya lokal model klasörünün tam yolu
HF_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2

# Gated/private modeller için HuggingFace token (public modeller için boş bırak)
HUGGINGFACE_TOKEN=

# Model davranış ayarları
HF_MAX_NEW_TOKENS=512
HF_TEMPERATURE=0.7

# ── Web Search (opsiyonel) ────────────────────────────────────────────────
# Ücretsiz key: https://tavily.com
TAVILY_API_KEY=

# ── LangSmith izleme (opsiyonel) ──────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=simple-agent
